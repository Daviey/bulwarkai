# Required - set these to your own values
project_id              = "your-project-id"
allowed_domains         = "yourcompany.com"
allowed_iam_members     = ["user:alice@yourcompany.com"]

# Optional - defaults shown
# region                = "europe-west2"
# response_mode         = "strict"
# fallback_model        = "gemini-2.5-flash"
# model_armor_template  = "test-template"
# api_keys              = ""
# user_agent_regex      = ""
# dlp_enabled           = false
# dlp_info_types        = "US_SOCIAL_SECURITY_NUMBER,CREDIT_CARD_NUMBER,EMAIL_ADDRESS,PHONE_NUMBER"

# OPA Policy Engine
# opa_enabled           = false
# opa_policy_content    = "package bulwarkai\ndefault allow := true\n"

# Rate Limiting
# rate_limit            = 0
# rate_limit_window     = "1m"

# Webhook Notifications
# webhook_url           = ""
# webhook_secret        = ""

# VPC Service Controls (optional - disabled by default)
# Requires org-level Access Context Manager policy to exist.
# vpc_sc_enabled        = false
# access_policy_name    = ""  # Access Context Manager policy name
# org_id                = ""  # GCP organization ID (number)
