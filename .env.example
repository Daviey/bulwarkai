# Required
GOOGLE_CLOUD_PROJECT=your-project-id
ALLOWED_DOMAINS=yourcompany.com

# Model
FALLBACK_GEMINI_MODEL=gemini-2.5-flash
# strict (default), fast (alias: input_only), or audit (alias: buffer)
RESPONSE_MODE=strict

# Model Armor
MODEL_ARMOR_TEMPLATE=test-template
MODEL_ARMOR_LOCATION=europe-west2

# Region
GOOGLE_CLOUD_LOCATION=europe-west2

# Auth (comma-separated, optional)
API_KEYS=
USER_AGENT_REGEX=

# DLP (set DLP_API=true to enable)
DLP_API=
DLP_LOCATION=europe-west2
DLP_INFO_TYPES=US_SOCIAL_SECURITY_NUMBER,CREDIT_CARD_NUMBER,EMAIL_ADDRESS,PHONE_NUMBER,PERSON_NAME,STREET_ADDRESS,DATE_OF_BIRTH
DLP_MIN_LIKELIHOOD=LIKELY
# DLP_ENDPOINT=https://dlp.googleapis.com

# OPA Policy Engine (set OPA_ENABLED=true to enable)
OPA_ENABLED=
OPA_POLICY_FILE=
OPA_POLICY_URL=

# Rate Limiting (per email, set RATE_LIMIT > 0 to enable)
RATE_LIMIT=
RATE_LIMIT_WINDOW=1m

# Webhook notifications for BLOCK events
WEBHOOK_URL=
WEBHOOK_SECRET=

# Server
PORT=8080
LOG_LEVEL=debug
LOG_PROMPT_MODE=truncate

# Local development (skips auth, uses ADC for Vertex AI)
LOCAL_MODE=

# Demo mode (returns canned responses, no Vertex AI calls, no cost)
DEMO_MODE=
